# Production frontend
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://allfilesconvertor.com
NEXT_PUBLIC_API_URL=https://api.allfilesconvertor.com
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
ALLOW_INTERNAL_API_HTTP=false

# Production backend
APP_ENV=production
FRONTEND_URL=https://allfilesconvertor.com
TEMP_STORAGE=local
ACK_SINGLE_INSTANCE_LOCAL_STORAGE=true
MAX_FILE_MB=100
MAX_BATCH_FILES=20
MAX_BATCH_MB=250
MAX_OUTPUT_MB=500
BATCH_CONCURRENCY=3
CLEANUP_TTL_MINUTES=10
TEMP_FILE_TTL_MINUTES=60
CLEANUP_INTERVAL_SECONDS=300
ANALYTICS_PATH=/data/all_files_convertor_analytics.json
LIBREOFFICE_BIN=/usr/bin/libreoffice
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_RETENTION_HOURS=24
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_BOUNDARY=false
REDIS_URL=redis://redis:6379/0
SENTRY_DSN=
